{
  "name": "pi-live-decision-board",
  "version": "0.1.3",
  "description": "Pi extension for a live, mutable assumptions and decisions board injected into agent context.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "extension",
    "decision-board"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maverobot/pi-live-decision-board.git"
  },
  "bugs": {
    "url": "https://github.com/Maverobot/pi-live-decision-board/issues"
  },
  "homepage": "https://github.com/Maverobot/pi-live-decision-board#readme",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "changelog": "node scripts/generate-changelog.mjs",
    "changelog:check": "node scripts/generate-changelog.mjs --check",
    "test": "npm run typecheck && node tests/live-decision-board-state.test.mjs && node tests/live-decision-board-extension.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.79.0 <1",
    "@earendil-works/pi-coding-agent": ">=0.79.0 <1",
    "@earendil-works/pi-tui": ">=0.79.0 <1",
    "typebox": "^1.1.0"
  },
  "pi": {
    "extensions": [
      "./extensions/live-decision-board.ts"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.79.1",
    "@earendil-works/pi-coding-agent": "0.79.1",
    "@earendil-works/pi-tui": "0.79.1",
    "@types/node": "22.19.21",
    "jiti": "^2.7.0",
    "typebox": "1.1.38",
    "typescript": "^6.0.3"
  },
  "files": [
    "extensions",
    "scripts",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ]
}
